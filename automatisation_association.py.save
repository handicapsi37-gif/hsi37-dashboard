import csv
import sqlite3
import os
from datetime import datetime
from dotenv import load_dotenv
from weasyprint import HTML
import resend

# 1. Configuration des clés secrètes (.env)
load_dotenv()
resend.api_key = os.getenv("RESEND_API_KEY")

DB_NAME = "association_hsi37.db"

def enregistrer_en_bdd(nom, prenom, email, adresse, cp, ville, montant):
    """Insère les données en base et calcule le numéro de reçu fiscal 
unique"""
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute("PRAGMA foreign_keys = ON;")
    
    date_du_jour = datetime.now().strftime("%d/%m/%Y")
    annee_en_cours = datetime.now().year
    
    try:
        # Gestion de la personne (évite les doublons)
        cursor.execute("SELECT id FROM personnes WHERE email = ?", 
(email,))
        resultat = cursor.fetchone()
        
        if resultat:
            personne_id = resultat[0]
        else:
            cursor.execute("""
                INSERT INTO personnes (nom, prenom, email, adresse, 
code_postal, ville)
                VALUES (?, ?, ?, ?, ?, ?)
            """, (nom, prenom, email, adresse, cp, ville))
            personne_id = cursor.lastrowid

        # Calcul du numéro de reçu fiscal (ex: 2026-0001)
        cursor.execute("SELECT COUNT(*) FROM dons_et_recus WHERE 
numero_recu_fiscal LIKE ?", (f"{annee_en_cours}-%",))
        nombre_dons = cursor.fetchone()[0]
        numero_recu = f"{annee_en_cours}-{(nombre_dons + 1):04d}"
        
        # Enregistrement du don
        chemin_pdf = f"recu_fiscal_{numero_recu}.pdf"
        cursor.execute("""
            INSERT INTO dons_et_recus (personne_id, montant, date_don, 
mode_paiement, numero_recu_fiscal, chemin_pdf_recu)
            VALUES (?, ?, ?, 'Carte Bancaire', ?, ?)
        """, (personne_id, montant, date_du_jour, numero_recu, 
chemin_pdf))
        
        conn.commit()
        return {"numero_recu": numero_recu, "date": date_du_jour, 
"chemin_pdf": chemin_pdf}
    except Exception as e:
        conn.rollback()
        print(f"❌ Erreur BDD pour {email} : {e}")
        return None
    finally:
        conn.close()


def generer_pdf_recu(donneur, infos_don):
    """Crée le fichier PDF à partir du modèle HTML/CSS avec le logo 
Wix"""
    html_content = f"""
    <html>
    <head>
        <meta charset="utf-8">
        <style>
            body {{ font-family: Arial, sans-serif; color: #333; margin: 
20px; }}
            .header {{ border-bottom: 2px solid #2c3e50; padding-bottom: 
10px; margin-bottom: 30px; }}
            .title {{ font-size: 18pt; font-weight: bold; color: #2c3e50; 
text-align: right; }}
            .box {{ background: #f8f9fa; padding: 15px; border-left: 4px 
solid #3498db; margin-bottom: 20px; }}
            .total {{ background: #2c3e50; color: white; font-size: 16pt; 
text-align: center; padding: 10px; font-weight: bold; margin: 20px 0; }}
        </style>
    </head>
    <body>
        <div class="header">
            <img src="https://static.wixstatic.com/media/votre_logo.png" 
width="120" alt="Logo HSI 37">
            <div class="title">REÇU FISCAL n° 
{infos_don['numero_recu']}</div>
        </div>
        <div class="box">
            <strong>Bénéficiaire :</strong> Habitat et Solidarité 
d'Indre-et-Loire (HSI 37)
        </div>
        <div class="box">
            <strong>Donateur :</strong> {donneur['prenom']} 
{donneur['nom']}<br>
            <strong>Adresse :</strong> {donneur['adresse']}, 
{donneur['cp']} {donneur['ville']}
        </div>
        <p>Le bénéficiaire certifie avoir reçu la somme de :</p>
        <div class="total">{donneur['montant']} EUR</div>
        <p>Date du versement : {infos_don['date']}</p>
        <p>Mode de versement : Carte Bancaire (En ligne)</p>
        <p style="font-size: 9pt; font-style: italic; margin-top: 50px;">
            Le bénéficiaire certifie que les dons ouvrent droit à la 
réduction d'impôt prévue aux articles 200 et 238 bis du CGI.
        </p>
    </body>
    </html>
    """
    HTML(string=html_content).write_pdf(infos_don['chemin_pdf'])


def envoyer_email_recu(donneur, infos_don):
    """Envoie le mail avec le PDF généré en pièce jointe via l'API 
Resend"""
    try:
        # Lecture du fichier PDF pour l'attacher au mail
        with open(infos_don['chemin_pdf'], "rb") as f:
            pdf_data = list(f.read())

        resend.Emails.send({
            "from": "Habitat & Solidarité <contact@hsi37.fr>", # Votre 
adresse sécurisée
            "to": donneur['email'],
            "subject": f"Votre reçu fiscal n° {infos_don['numero_recu']} 
🧡",
            "html": f"<p>Bonjour {donneur['prenom']},</p><p>Merci pour 
votre don. Vous trouverez votre reçu fiscal en pièce jointe.</p>",
            "attachments": [
                {
                    "content": pdf_data,
                    "filename": infos_don['chemin_pdf']
                }
            ]
        })
        print(f"📧 Email envoyé avec succès à {donneur['email']}")
    except Exception as e:
        print(f"❌ Erreur d'envoi d'email à {donneur['email']} : {e}")


def piloter_le_traitement_global():
    """Fonction principale qui lit le CSV et lance la chaîne 
automatique"""
    if not os.path.exists("dons.csv"):
        print("Le fichier dons.csv est introuvable.")
        return

    with open("dons.csv", mode="r", encoding="utf-8") as fichier:
        lecteur_csv = csv.DictReader(fichier)
        
        for ligne in lecteur_csv:
            print(f"\n--- Traitement de {ligne['prenom']} {ligne['nom']} 
---")
            
            # 1. Enregistrement en base de données et calcul du numéro 
unique
            infos_don = enregistrer_en_bdd(
                nom=ligne['nom'], prenom=ligne['prenom'], 
email=ligne['email'],
                adresse=ligne['adresse'], cp=ligne['cp'], 
ville=ligne['ville'], 
                montant=float(ligne['montant'])
            )
            
            if infos_don:
                # 2. Génération physique du PDF
                generer_pdf_recu(ligne, infos_don)
                print(f"📄 PDF généré : {infos_don['chemin_pdf']}")
                
                # 3. Envoi par e-mail
                envoyer_email_recu(ligne, infos_don)
                
                # Optionnel : Supprimer le fichier PDF local après envoi 
pour ne pas encombrer le serveur
                # os.remove(infos_don['chemin_pdf'])

# Lancement du programme
if __name__ == "__main__":
    piloter_le_traitement_global()
